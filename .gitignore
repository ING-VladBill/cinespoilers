# 🔐 Django .gitignore

# Python

**pycache**/
*.py[cod]
*$py.class

# Entornos virtuales

venv/
env/
.venv/

# Variables de entorno

.env

# Base de datos

db.sqlite3
*.sqlite3

# Archivos de Django

*.log
staticfiles/
media/

# Migraciones compiladas (opcional, pero recomendable)

**/migrations/*.pyc
**/migrations/**pycache**/

# Archivos de sistema

.DS_Store
Thumbs.db

# VS Code

.vscode/

# JetBrains (PyCharm, etc.)

.idea/

# Archivos temporales

*.swp
*.swo

# Coverage / testing

.coverage
htmlcov/
.tox/
.pytest_cache/

# Node (por si luego haces frontend)

node_modules/

# Archivos de build

dist/
build/
